# Copy this file to .env and fill in the connection string for DB-connected runs.
# When DB_CONNECTION_STRING is not set, all notebooks fall back to CSV files
# in lighthouse_csv_v7/ so they remain independently runnable.
DB_CONNECTION_STRING=mssql+pyodbc://user:pass@server.database.windows.net/dbname?driver=ODBC+Driver+17+for+SQL+Server
